@page
@model PANExpenseTracker.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}
<div class="empty-state">
    <div class="empty-icon">⚠️</div>
    <h3>Something went wrong</h3>
    <p style="color:var(--muted);margin-top:8px">@Model.RequestId</p>
    <a asp-page="/Index" class="btn btn-primary" style="margin-top:16px">← Back to Dashboard</a>
</div>
