@page
@model PANExpenseTracker.Pages.Expenses.IndexModel

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">✅ @TempData["SuccessMessage"]</div>
}

<div class="stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px;">
    <div class="stat-card red">
        <div class="stat-label">Total Expenses</div>
        <div class="stat-value red">₹@Model.TotalAmount.ToString("N2")</div>
        <div class="stat-sub">In selected period</div>
    </div>
    <div class="stat-card blue">
        <div class="stat-label">No. of Entries</div>
        <div class="stat-value blue">@Model.Expenses.Count()</div>
    </div>
    <div class="stat-card yellow">
        <div class="stat-label">Avg per Entry</div>
        <div class="stat-value yellow">₹@(Model.Expenses.Any() ? (Model.TotalAmount / Model.Expenses.Count()).ToString("N2") : "0.00")</div>
    </div>
</div>

<div class="filter-bar">
    <button class="filter-btn" data-period="day">Today</button>
    <button class="filter-btn" data-period="week">Week</button>
    <button class="filter-btn" data-period="month">Month</button>
    <button class="filter-btn" data-period="year">Year</button>
    <button class="filter-btn" data-period="all">All</button>
    <span class="filter-sep">|</span>
    <button class="filter-btn" data-period="custom">Custom</button>
    <div style="margin-left:auto">
        <button class="btn btn-primary" onclick="openModal('addExpModal')">+ Add Expense</button>
    </div>
</div>
<div id="customRangeRow" style="display:none;align-items:center;gap:10px;margin-bottom:16px;">
    <input type="date" id="customFrom" value="@Model.Filter.From?.ToString("yyyy-MM-dd")" style="width:160px">
    <span style="color:var(--muted)">to</span>
    <input type="date" id="customTo" value="@Model.Filter.To?.ToString("yyyy-MM-dd")" style="width:160px">
    <button class="btn btn-primary btn-sm" id="applyCustomRange">Apply</button>
</div>

@if (!Model.Expenses.Any())
{
    <div class="empty-state">
        <div class="empty-icon">💸</div>
        <h3>No expenses found</h3>
        <p>Start tracking your expenses above.</p>
    </div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Details</th>
                    <th>Category</th>
                    <th>Amount</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Expenses)
                {
                    <tr>
                        <td style="font-family:'JetBrains Mono',monospace;font-size:12.5px">@e.ExpenseDate.ToString("dd MMM yyyy")</td>
                        <td style="font-weight:500">@e.Details</td>
                        <td><span class="badge badge-red">@e.CategoryIcon @e.CategoryName</span></td>
                        <td class="amount-cell" style="color:var(--accent2)">₹@e.Amount.ToString("N2")</td>
                        <td style="color:var(--muted);font-size:12.5px">@(e.Notes ?? "—")</td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <button class="btn btn-outline btn-sm"
                                    onclick="openEditExpModal(@e.ExpenseId,'@e.ExpenseDate.ToString("yyyy-MM-dd")','@e.Details.Replace("'","\\'")',@e.CategoryId,@e.Amount,'@e.Notes?.Replace("'","\\'")')">
                                    ✏️
                                </button>
                                <form method="post" asp-page-handler="Delete" id="del-exp-@e.ExpenseId" style="display:inline">
                                    <input type="hidden" name="id" value="@e.ExpenseId" />
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn btn-danger btn-sm"
                                        onclick="confirmDelete('del-exp-@e.ExpenseId')">🗑️</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- ADD EXPENSE MODAL -->
<div class="modal-overlay" id="addExpModal">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">💸 Add Expense</span>
            <button class="modal-close" onclick="closeModal('addExpModal')">✕</button>
        </div>
        <form method="post" asp-page-handler="Add">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <div class="form-group">
                    <label>Date *</label>
                    <input name="expenseDate" type="date" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label>Category *</label>
                    <select name="categoryId" required>
                        <option value="">-- Select --</option>
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.CategoryId">@c.Icon @c.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group span2">
                    <label>Details *</label>
                    <input name="details" required placeholder="What was this expense for?" />
                </div>
                <div class="form-group">
                    <label>Amount (₹) *</label>
                    <input name="amount" type="number" step="0.01" min="0" required placeholder="0.00" />
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <input name="notes" placeholder="Optional notes" />
                </div>
            </div>
            <div class="form-actions" style="margin-top:16px">
                <button type="submit" class="btn btn-primary">Save Expense</button>
                <button type="button" class="btn btn-outline" onclick="closeModal('addExpModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT EXPENSE MODAL -->
<div class="modal-overlay" id="editExpModal">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">✏️ Edit Expense</span>
            <button class="modal-close" onclick="closeModal('editExpModal')">✕</button>
        </div>
        <form method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <input type="hidden" name="expenseId" id="editExpId" />
            <div class="form-grid">
                <div class="form-group">
                    <label>Date *</label>
                    <input name="expenseDate" id="editExpDate" type="date" required />
                </div>
                <div class="form-group">
                    <label>Category *</label>
                    <select name="categoryId" id="editExpCat" required>
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.CategoryId">@c.Icon @c.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group span2">
                    <label>Details *</label>
                    <input name="details" id="editExpDetails" required />
                </div>
                <div class="form-group">
                    <label>Amount (₹) *</label>
                    <input name="amount" id="editExpAmount" type="number" step="0.01" required />
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <input name="notes" id="editExpNotes" />
                </div>
            </div>
            <div class="form-actions" style="margin-top:16px">
                <button type="submit" class="btn btn-primary">Update Expense</button>
                <button type="button" class="btn btn-outline" onclick="closeModal('editExpModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openEditExpModal(id, date, details, catId, amount, notes) {
    document.getElementById('editExpId').value = id;
    document.getElementById('editExpDate').value = date;
    document.getElementById('editExpDetails').value = details;
    document.getElementById('editExpCat').value = catId;
    document.getElementById('editExpAmount').value = amount;
    document.getElementById('editExpNotes').value = notes || '';
    openModal('editExpModal');
}
</script>
}
